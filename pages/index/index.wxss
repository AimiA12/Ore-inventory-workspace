  overflow: hidden;
  box-sizing: border-box;
}

.suggest-chip {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #eef3ef;
  border: 1rpx solid #cbd8cf;
  color: #315a47;
  font-size: 23rpx;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.secondary-btn,
.primary-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 850;
  margin: 0;
  padding: 0;
}

.secondary-btn {
  margin-bottom: 16rpx;
  background: #e8f1ec;
  color: #1c5e49;
  border: 1rpx solid #cbd8cf;
}

.primary-btn {
  background: #1c5e49;
