  font-weight: 750;
}

.optional {
  color: #8a948e;
  font-size: 20rpx;
  font-weight: 500;
}

input,
textarea,
.picker {
  width: 100%;
  min-height: 70rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  background: #f7f1e6;
  border: 1rpx solid #ded3c1;
  color: #1d2b25;
  font-size: 25rpx;
  box-sizing: border-box;
}

textarea {
  min-height: 70rpx;
  padding-top: 17rpx;
  padding-bottom: 17rpx;
  line-height: 1.35;
}

.picker {
  line-height: 70rpx;
}

.two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.suggest-list {
  margin: 14rpx 0 16rpx;
}

.assay-suggest-list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
