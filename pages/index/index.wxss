}

.sticky-save {
  position: sticky;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 4;
  box-shadow: 0 12rpx 28rpx rgba(28, 94, 73, 0.18);
}

.draft-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
