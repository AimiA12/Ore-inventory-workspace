.draft-row {
  display: grid;
  grid-template-columns: 1fr 1fr 56rpx;
  align-items: center;
  gap: 10rpx;
  min-height: 58rpx;
  padding: 8rpx 10rpx 8rpx 14rpx;
  border-radius: 8rpx;
  background: #f7f1e6;
  color: #2c3832;
  font-size: 23rpx;
}

.draft-metal {
  font-weight: 800;
}

.icon-remove {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #f2e6dc;
  color: #8b3f31;
  font-size: 30rpx;
  margin: 0;
  padding: 0;
}

.weight-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.big-number {
  margin-top: 6rpx;
  color: #14231f;
  font-size: 44rpx;
  font-weight: 900;
}

.weight-side {
  color: #5f6c65;
  font-size: 23rpx;
  line-height: 1.55;
  text-align: right;
}

.table-scroll {
  width: 100%;
  margin-bottom: 18rpx;
}

.sale-table {
  min-width: 1880rpx;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #dfd6c6;
}

.table-row {
  display: grid;
  grid-template-columns: 160rpx 170rpx 120rpx 112rpx 120rpx 112rpx 220rpx 120rpx 210rpx 150rpx 170rpx;
  align-items: center;
  min-height: 68rpx;
  background: #fffdf7;
  border-bottom: 1rpx solid #ebe3d6;
}

.table-row.single-pile-table {
  grid-template-columns: 132rpx 170rpx 120rpx 112rpx 120rpx 112rpx 220rpx 120rpx 210rpx 150rpx 170rpx;
}

.table-row > view {
  min-height: 68rpx;
  padding: 10rpx;
  color: #2d3933;
  font-size: 22rpx;
  line-height: 1.3;
  word-break: break-word;
  box-sizing: border-box;
  border-right: 1rpx solid #ebe3d6;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.table-head {
  background: #13221e;
}

.table-head > view {
  color: #fffaf0;
  font-weight: 850;
}

.metal-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.pile-cell {
  color: #14231f;
  font-weight: 850;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.25;
}

.single-pile-table .pile-cell {
  background: #f8f3ea;
  align-self: stretch;
  font-size: 22rpx;
  border-bottom: none;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.single-pile-table .pile-cell-ghost {
  color: transparent;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex: 0 0 auto;
}

.price-input {
  min-height: 58rpx;
  height: 58rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  background: #f7f1e6;
  text-align: center;
}

.total-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #14231f;
  font-size: 32rpx;
  font-weight: 900;
}

.total-panel view:last-child {
  color: #1c5e49;
}

.total-sub {
  margin-top: 6rpx;
  color: #7a867f;
  font-size: 22rpx;
  font-weight: 700;
  text-align: inherit;
}

.complete-sale-btn {
  margin-top: 18rpx;
}

@media (max-width: 360px) {
  .page {
    padding-left: 18rpx;
    padding-right: 18rpx;
  }

  .pile-card {
    grid-template-columns: 138rpx 1fr;
    gap: 12rpx;
  }

  .heap-wrap {
    height: 132rpx;
  }

  .heap {
    height: 94rpx;
  }

  .info-grid {
    grid-template-columns: 1fr;
  }

  .page-title {
    font-size: 38rpx;
  }

  .sale-bar {
    left: 16rpx;
    right: 16rpx;
    min-height: 88rpx;
    padding: 14rpx;
  }

  .sale-count {
    font-size: 23rpx;
  }

  .delete-selected-btn,
  .sell-btn {
    height: 64rpx;
    line-height: 64rpx;
    font-size: 22rpx;
  }

  .delete-selected-btn {
    width: 82rpx;
    max-width: 82rpx;
    flex-basis: 82rpx;
  }

  .sell-btn {
    width: 88rpx;
    max-width: 88rpx;
    flex-basis: 88rpx;
  }

  .fab {
    width: 31rpx;
    height: 62rpx;
    border-radius: 13rpx;
    font-size: 30rpx;
  }

  .back-btn {
    width: 58rpx;
    height: 54rpx;
    font-size: 27rpx;
  }

  .head-copy {
    padding-right: 0;
  }

  .assay-suggest-list {
    gap: 8rpx;
  }

  .suggest-chip {
    height: 54rpx;
    line-height: 52rpx;
    padding: 0 8rpx;
  }
}

@media (min-width: 760px) {
  .page {
    max-width: 920px;
    margin: 0 auto;
  }
}
